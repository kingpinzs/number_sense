  <interfaces-to-create>
    <interface name="MistakeType">
      <description>Enum/union of all possible mistake types</description>
      <values>
        <!-- Number Line -->
        <value>overestimation</value>
        <value>underestimation</value>
        <value>magnitude_error</value>
        <value>boundary_error</value>
        <!-- Spatial Rotation -->
        <value>rotation_confusion</value>
        <value>mirror_confusion</value>
        <value>complexity_threshold</value>
        <!-- Math Operations -->
        <value>operation_weakness</value>
        <value>magnitude_threshold</value>
        <value>speed_accuracy_tradeoff</value>
      </values>
    </interface>

    <interface name="CategorizedMistake">
      <description>Single categorized mistake entry</description>
      <fields>
        <field name="drillId" type="string">uuid()</field>
        <field name="mistakeType" type="MistakeType">Type of mistake detected</field>
        <field name="severity" type="'minor' | 'moderate' | 'severe'">Based on error magnitude</field>
        <field name="timestamp" type="number">Date.now()</field>
        <field name="drillContext" type="object">{ module, difficulty, ... }</field>
      </fields>
    </interface>

    <interface name="MistakePattern">
      <description>Detected pattern from multiple mistakes</description>
      <fields>
        <field name="patternType" type="MistakeType">Type of pattern</field>
        <field name="occurrences" type="number">Count of this mistake type</field>
        <field name="recentDrills" type="number">Window size analyzed (e.g., last 5)</field>
        <field name="confidence" type="number">0-1 confidence in pattern</field>
        <field name="detectedAt" type="number">Timestamp of detection</field>
      </fields>
    </interface>

    <interface name="AnalysisResult">
      <description>Complete analysis output for a session</description>
      <fields>
        <field name="sessionId" type="number">Session analyzed</field>
        <field name="analyzedAt" type="number">Timestamp</field>
        <field name="mistakes" type="CategorizedMistake[]">All categorized mistakes</field>
        <field name="patterns" type="MistakePattern[]">Detected patterns</field>
        <field name="recommendations" type="string[]">Suggested focus areas</field>
      </fields>
    </interface>
  </interfaces-to-create>

  <severity-calculation>
    <module name="number_line">
      <rule severity="severe">Error greater than 20% of range</rule>
      <rule severity="moderate">Error between 5% and 20% of range</rule>
      <rule severity="minor">Error less than 5% of range</rule>
    </module>

    <module name="spatial_rotation">
      <rule severity="severe">Wrong on simple shapes (circle, square, triangle)</rule>
      <rule severity="moderate">Wrong on medium complexity shapes</rule>
      <rule severity="minor">Wrong only on complex/irregular shapes</rule>
    </module>

    <module name="math_operations">
      <rule severity="severe">Basic facts wrong (single digit, addition)</rule>
      <rule severity="moderate">Medium difficulty wrong (double digit, subtraction)</rule>
      <rule severity="minor">Only hard problems wrong (multiplication, large numbers)</rule>
    </module>
  </severity-calculation>

  <functions-to-implement>
    <function name="analyzeDrillResult">
      <signature>(result: DrillResult) => CategorizedMistake | null</signature>
      <description>Analyze single drill result, return categorized mistake if incorrect</description>
      <pure>true</pure>
    </function>

    <function name="categorizeMistake">
      <signature>(result: DrillResult) => { type: MistakeType; severity: Severity }</signature>
      <description>Determine mistake type and severity from drill result</description>
      <pure>true</pure>
    </function>

    <function name="detectPattern">
      <signature>(mistakes: CategorizedMistake[], windowSize?: number) => MistakePattern[]</signature>
      <description>Find patterns in mistake history (default window: 5 drills)</description>
      <algorithm>2+ mistakes of same type within window = pattern</algorithm>
      <pure>true</pure>
    </function>

    <function name="analyzeSession">
      <signature>(results: DrillResult[]) => AnalysisResult</signature>
      <description>Full session analysis combining all functions</description>
      <pure>true</pure>
    </function>
  </functions-to-implement>

