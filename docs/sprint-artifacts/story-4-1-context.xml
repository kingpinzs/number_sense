  <story-details>
    <title>Implement Mistake Analysis Engine</title>
    <user-story>
      As a system analyzing user performance,
      I want to detect error patterns from drill results in real-time,
      So that I can identify which specific skills need targeted practice.
    </user-story>

    <implementation-location>src/services/adaptiveDifficulty/mistakeAnalyzer.ts</implementation-location>
  </story-details>

  <acceptance-criteria>
    <criterion id="AC-1" category="error-detection">
      <title>Number Line Error Patterns</title>
      <requirements>
        <item>Consistent overestimation (user always places too high)</item>
        <item>Consistent underestimation (user always places too low)</item>
        <item>Magnitude errors (struggles with 100+ range but OK with 0-100)</item>
        <item>Boundary errors (struggles near 0 or 100)</item>
      </requirements>
    </criterion>

    <criterion id="AC-2" category="error-detection">
      <title>Spatial Rotation Error Patterns</title>
      <requirements>
        <item>Rotation confusion (can't distinguish 90 vs 180 degrees)</item>
        <item>Mirroring confusion (mistakes mirror for rotation)</item>
        <item>Complexity threshold (struggles with irregular shapes but OK with simple)</item>
      </requirements>
    </criterion>

    <criterion id="AC-3" category="error-detection">
      <title>Math Operations Error Patterns</title>
      <requirements>
        <item>Operation-specific weakness (good at addition, struggles with subtraction)</item>
        <item>Magnitude threshold (OK with single-digit, struggles with double-digit)</item>
        <item>Speed vs accuracy trade-off (fast but inaccurate vs slow but accurate)</item>
      </requirements>
    </criterion>

    <criterion id="AC-4" category="categorization">
      <title>Mistake Categorization</title>
      <requirements>
        <item>Each mistake tagged with: drillId, mistakeType, severity, timestamp, drillContext</item>
        <item>mistakeType enum: 'overestimation' | 'rotation_confusion' | 'magnitude_error' | etc.</item>
        <item>severity levels: 'minor' | 'moderate' | 'severe' (based on error magnitude)</item>
      </requirements>
    </criterion>

    <criterion id="AC-5" category="real-time">
      <title>Real-Time Analysis</title>
      <requirements>
        <item>Analyzer runs after every 3 drills (sliding window)</item>
        <item>Maintains session-level mistake buffer (last 10 drills)</item>
        <item>Pattern detection: 2+ mistakes of same type = pattern detected</item>
      </requirements>
    </criterion>

    <criterion id="AC-6" category="integration">
      <title>Integration Requirements</title>
      <requirements>
        <item>Analysis results stored in SessionContext for use by adaptive engine</item>
        <item>Pure functions for testability: analyzeDrillResult(), detectPattern(), categorizeMistake()</item>
        <item>Export TypeScript interfaces: MistakePattern, AnalysisResult</item>
      </requirements>
    </criterion>
  </acceptance-criteria>

